# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL credentials for the TimescaleDB instance
POSTGRES_USER=deko
POSTGRES_PASSWORD=changeme

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of the API (used by the web app to make server-side requests
# and for CORS validation). If you're running behind a reverse proxy, set
# this to your externally reachable API URL.
API_URL=http://localhost:8000

# Public URL of the web app. Used by the API for CORS and redirect purposes.
WEB_URL=http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# 32-byte secret key used to encrypt sensitive data (e.g. service tokens).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_a_32_byte_hex_secret

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins for the API.
# Leave blank to use WEB_URL only, or add additional origins if needed.
# Example: http://localhost:3000,https://dash.example.com
CORS_ORIGINS=

# ── Ports (optional) ──────────────────────────────────────────────────────────
# Host ports the API and web containers will be exposed on.
# Defaults are 8000 (API) and 3000 (web). Only change if those ports conflict.
API_PORT=8000
WEB_PORT=3000
